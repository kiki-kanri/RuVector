# Example environment file for ruvector-hailo-worker.
# Copy to /etc/ruvector-hailo.env and customise.
# The systemd unit reads this via EnvironmentFile=-.

# Listen address. 0.0.0.0:50051 is the cluster default; override to
# 127.0.0.1:N if you only want local clients, or to a tailnet-only IP
# (`tailscale ip -4` on the host) if you want tailnet-only access.
RUVECTOR_WORKER_BIND=0.0.0.0:50051

# Path to the directory containing the model artifacts. Two layouts work
# (worker auto-detects which is present):
#
#   NPU path (iter 167, requires --features hailo + Hailo-8 NPU):
#     model_dir/model.hef
#     model_dir/vocab.txt
#     model_dir/special_tokens.json
#
#   CPU fallback (iter 134, requires --features cpu-fallback):
#     model_dir/model.safetensors
#     model_dir/tokenizer.json
#     model_dir/config.json
#
# Run deploy/download-cpu-fallback-model.sh to fetch the cpu-fallback
# trio with sha256-pinned downloads (~91 MB total).
# See crates/ruvector-hailo/models/README.md for the compile recipe.
RUVECTOR_MODEL_DIR=/var/lib/ruvector-hailo/models/all-minilm-l6-v2

# Tracing filter — info is the production default; ruvector_hailo_worker=debug
# turns on per-RPC spans without flooding upstream noise.
RUST_LOG=info,ruvector_hailo_cluster=info,ruvector_hailo=info

# Iter 147 — parallel inference pool size for the cpu-fallback path.
# Each slot holds an independent candle BertModel; the OS dedupes the
# 90 MB safetensors mmap so memory cost is ~100 MB total at pool=4
# (vs 90 MB at pool=1). Set to your physical core count for max throughput.
# Pi 5 (4 cores): 4. Single-board with 2 cores: 2. Default 1 (backward compat).
# No-op when --features cpu-fallback isn't built in.
RUVECTOR_CPU_FALLBACK_POOL_SIZE=4

# Iter 234-239 — parallel pipeline pool size for the NPU path. Each slot
# is an independent HailoRT network group + vstream pair on the shared
# vdevice. Iter-236 measurement on cognitum-v0 (Pi 5 + Hailo-8) confirmed
# that throughput is *not* affected by pool size — HailoRT serializes
# inference across network groups at the NPU level — but **p50 latency
# under concurrency drops 23%** (56.7ms → 43.5ms at concurrency=4)
# because each request gets its own host-side queue slot rather than
# contending on one mutex. Pool=2 captures the full latency win; pool=4
# is no better. Iter-239 measured RSS cost on cognitum-v0:
#
#   pool=1 → 87 MB RSS  (baseline)
#   pool=2 → 142 MB RSS (+55 MB / +64%)
#   pool=4 → 251 MB RSS (+164 MB total / nearly 3x baseline)
#
# Per-slot overhead is ~55 MB — most of it HailoRT's DMA + ring buffers
# per configured network group; the safetensors mmap (~90 MB) and HEF
# (~4 MB) are shared via the kernel page cache. Pool=2 is the latency-
# win sweet spot; pool=4 buys nothing extra and costs an extra 109 MB.
# Default 2 since the multi-bridge deploy (mmwave + ruview-csi +
# ruvllm bridges hitting one Pi) sees real concurrent load. Set to 1
# to skip the pool entirely (matches the iter-227 baseline) — useful
# on memory-constrained 4 GB Pi 5 deploys.
# No-op without --features hailo,cpu-fallback.
RUVECTOR_NPU_POOL_SIZE=2

# Iter 174 — opt-in HEF integrity pin (defense in depth on top of the
# iter-173 magic check). When set, the worker streams sha256 over
# model.hef at startup and refuses to start if the digest doesn't
# match this value. Catches a substituted HEF that satisfies the
# magic check but isn't the artifact you intended to deploy.
#
# The published GitHub Release HEF (hailo-encoder-v0.1.0-iter156b)
# has sha256 cdbc892765d3099f74723ee6c28ab3f0daade2358827823ba08d2969b07ebd40
# — paste that value here for the iter-156b deploy. ~16 ms cost at
# boot on Pi 5 NEON; no per-embed cost. Comment out for back-compat.
#RUVECTOR_HEF_SHA256=cdbc892765d3099f74723ee6c28ab3f0daade2358827823ba08d2969b07ebd40

# ----------------------------------------------------------------------
# DoS gate stack (iter 180-200). All have safe production defaults; the
# values shown below are the same defaults the worker logs at startup,
# documented here so operators have a single place to tune them. Floor
# values are baked into the worker code so a misconfig (e.g. setting a
# cap to 0) can't lock out legitimate traffic.
# ----------------------------------------------------------------------

# Iter 180 — gRPC max_decoding_message_size cap. tonic's transport
# default is ~4 MB per RPC. Sentence-transformer text is normally
# <10 KB, so 64 KB is 6× safety margin. Floor 4 KB.
#RUVECTOR_MAX_REQUEST_BYTES=65536

# Iter 190 — gRPC max_encoding_message_size cap. The worker's response
# is Vec<f32>[384] ≈ 1.6 KB; capping at 16 KB is 10× safety. Defense
# in depth on the response side. Floor 4 KB.
#RUVECTOR_MAX_RESPONSE_BYTES=16384

# Iter 181 — HTTP/2 SETTINGS_MAX_CONCURRENT_STREAMS. Caps the in-flight
# stream count per TCP connection so a single attacker socket can't
# pump unbounded RPCs at the worker. iter-179 streaming sweep peaked
# at 8 streams; 256 is 32× legit headroom. Floor 8.
#RUVECTOR_MAX_CONCURRENT_STREAMS=256

# Iter 182 — per-RPC handler timeout. tonic returns Status::cancelled
# when this fires. iter-179 measured worst legit latency at 910 ms
# (b=16 streaming); 30 s gives 30× headroom. Floor 2 s so a misconfig
# can't kill normal embeds.
#RUVECTOR_REQUEST_TIMEOUT_SECS=30

# Iter 183 — explicit CVE-2023-44487 rapid-reset cap. hyper/h2's
# default is 20 unprocessed RST_STREAM frames; 32 is a small step
# above to leave room for legit reset jitter while still limiting
# attacker amplification. Floor 8.
#RUVECTOR_MAX_PENDING_RESETS=32

# Iter 184 — HTTP/2 keepalive ping interval. Reclaims half-closed TCP
# state from crashed/partitioned clients. 0 disables (cellular,
# ping-hostile networks). Floor 10 s. Pong timeout is hyper's
# default 20 s.
#RUVECTOR_HTTP2_KEEPALIVE_SECS=60

# Iter 199 — embed_stream batch-size cap. Bounds the per-RPC NPU work
# an attacker can force by tightly packing many tiny texts into the
# iter-180 byte cap. iter-179 streaming sweep peaked at b=16; 256 is
# 16× legit headroom. Returns InvalidArgument when exceeded. Floor 1.
#RUVECTOR_MAX_BATCH_SIZE=256

# Iter 191 — HailoRT vstream FFI timeout. Bounds how long a single
# NPU forward pass can hang before HAILO_TIMEOUT (status 4) surfaces.
# Steady-state embed cost is ~14 ms; 2 s is 143× headroom for thermal
# throttling. Floor 100 ms.
#RUVECTOR_NPU_VSTREAM_TIMEOUT_MS=2000

# Iter 185 — shutdown teardown mode. Default off because every clean
# HailoRT teardown SEGV'd in the upstream library; the worker exits
# with mem::forget + process::exit(0), letting the OS reap fds + mmaps.
# Set to "1" to attempt the slow drop path (reserved for a future
# HailoRT release that fixes the upstream bug). Floor on _DRAIN_MS:
# 0 (disabled), default 500 ms when FORCE_CLEAN=1.
#RUVECTOR_SHUTDOWN_FORCE_CLEAN=0
#RUVECTOR_SHUTDOWN_DRAIN_MS=500

# ADR-172 §3b iter-104/105 — opt-in per-peer rate limit. 0 = disabled
# (the iter-101 fingerprint binding requires the cache off when this
# is unset; see worker.rs for the gate). Iter 200 — when enabled, the
# embed_stream RPC debits N tokens (one per item in the batch) so a
# 1 RPS peer is genuinely capped at 1 embed/sec end-to-end whether
# they unary or batch.
#RUVECTOR_RATE_LIMIT_RPS=10
#RUVECTOR_RATE_LIMIT_BURST=20

# ADR-172 §3c iter-103 — embed text content audit log mode. None
# (default) renders text as "-" in logs; "hash" renders blake3 of
# the text (cross-system correlation without leakage); "full"
# renders the raw text (debug-only — never use in prod with
# untrusted input).
#RUVECTOR_LOG_TEXT_CONTENT=none

# ADR-172 §1a iter-99 — TLS server cert + key (rustls). Both must be
# set or both unset; partial config halts at startup. Without TLS,
# the worker serves plaintext gRPC and assumes the caller (Tailscale,
# upstream proxy) handles transport security.
#RUVECTOR_TLS_CERT=/etc/ruvector-hailo/server.crt
#RUVECTOR_TLS_KEY=/etc/ruvector-hailo/server.key

# ADR-172 §1b iter-100 — optional mTLS. When set alongside
# RUVECTOR_TLS_CERT/_KEY, the worker requires every client to present
# a cert chaining to this CA bundle. Pair with the iter-187/188/189
# `--tls-client-cert` / `--tls-client-key` flags on the bench / embed /
# stats CLIs.
#RUVECTOR_TLS_CLIENT_CA=/etc/ruvector-hailo/clients-ca.pem
