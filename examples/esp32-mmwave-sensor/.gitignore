# Cargo / Rust build artifacts
/target/

# esp-idf-sys downloaded toolchain + framework (~2.8 GB; reproducible
# from the rust-toolchain pin + ESP_IDF_VERSION env var in .cargo/config.toml).
/.embuild/

# Local sdkconfig generated by esp-idf-sys at build time. The committed
# `sdkconfig.defaults` + `sdkconfig.defaults.esp32s3` are the source of truth.
/sdkconfig
/sdkconfig.old

